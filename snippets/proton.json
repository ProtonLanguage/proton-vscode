{
  "Variable": {
    "prefix": "var",
    "body": [
      "var:local ${1:name} = ${2:value};"
    ],
    "description": "Declare a local variable"
  },
  "Constant": {
    "prefix": "const",
    "body": [
      "const:local ${1:NAME} = ${2:value};"
    ],
    "description": "Declare a local constant"
  },
  "Module Variable": {
    "prefix": "mod",
    "body": [
      "module.${1:name} = ${2:value};"
    ],
    "description": "Declare a global module variable"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:params}) do",
      "\t${3:-- code here}",
      "end;"
    ],
    "description": "Define a function"
  },
  "Function with Return": {
    "prefix": "funcr",
    "body": [
      "func ${1:name}(${2:params}) do",
      "\t${3:-- code here}",
      "\treturn ${4:value};",
      "end;"
    ],
    "description": "Define a function with return"
  },
  "If": {
    "prefix": "if",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- code here}",
      "end;"
    ],
    "description": "If statement"
  },
  "If Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- code here}",
      "else do",
      "\t${3:-- code here}",
      "end;"
    ],
    "description": "If else statement"
  },
  "If Elseif Else": {
    "prefix": "ifee",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- code here}",
      "elseif ${3:condition} do",
      "\t${4:-- code here}",
      "else do",
      "\t${5:-- code here}",
      "end;"
    ],
    "description": "If elseif else"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} do",
      "\t${2:-- code here}",
      "end;"
    ],
    "description": "While loop"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1} to ${3:10} do",
      "\t${4:-- code here}",
      "end;"
    ],
    "description": "For loop"
  },
  "For Each": {
    "prefix": "foreach",
    "body": [
      "for each ${1:item} in ${2:list} do",
      "\t${3:-- code here}",
      "end;"
    ],
    "description": "For each loop"
  },
  "Try Catch": {
    "prefix": "try",
    "body": [
      "try do",
      "\t${1:-- code here}",
      "catch ${2:err} do",
      "\tprint(\"Error: \" .. ${2:err});",
      "end;"
    ],
    "description": "Try catch"
  },
  "Print": {
    "prefix": "print",
    "body": [
      "print(${1:\"message\"});"
    ],
    "description": "Print to console"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import ${1:std.network};"
    ],
    "description": "Import a module"
  },
  "Datastore Save": {
    "prefix": "dssave",
    "body": [
      "datastore.save(\"${1:key}\", {",
      "\t${2:field}: ${3:value}",
      "});"
    ],
    "description": "Save to datastore"
  },
  "Datastore Load": {
    "prefix": "dsload",
    "body": [
      "var:local ${1:data} = datastore.load(\"${2:key}\");",
      "if datastore.exists(\"${2:key}\") do",
      "\t${3:-- use data}",
      "else do",
      "\t-- no save found",
      "end;"
    ],
    "description": "Load from datastore"
  },
  "Network onConnect": {
    "prefix": "onconnect",
    "body": [
      "network.onConnect(func(player) do",
      "\t${1:-- player connected}",
      "end);"
    ],
    "description": "Handle player connect"
  },
  "Network onDisconnect": {
    "prefix": "ondisconnect",
    "body": [
      "network.onDisconnect(func(player) do",
      "\t${1:-- player disconnected}",
      "end);"
    ],
    "description": "Handle player disconnect"
  },
  "Network broadcast": {
    "prefix": "broadcast",
    "body": [
      "network.broadcast(\"${1:EventName}\", {",
      "\t${2:key}: ${3:value}",
      "});"
    ],
    "description": "Broadcast to all players"
  },
  "Network send": {
    "prefix": "netsend",
    "body": [
      "network.send(${1:player}, \"${2:EventName}\", {",
      "\t${3:key}: ${4:value}",
      "});"
    ],
    "description": "Send to one player"
  },
  "Server Template": {
    "prefix": "server",
    "body": [
      "--[[",
      "  server.pros",
      "  Proton# Multiplayer Server",
      "]]",
      "",
      "import std.network;",
      "",
      "const:local MAX_PLAYERS = ${1:10};",
      "module.players = [];",
      "",
      "network.onConnect(func(player) do",
      "\tmodule.players.push(player);",
      "\tnetwork.broadcastExcept(player, \"PlayerJoined\", { id: player.id, name: player.name });",
      "\tnetwork.send(player, \"Welcome\", { yourId: player.id, players: module.players });",
      "end);",
      "",
      "network.onDisconnect(func(player) do",
      "\tvar:local idx = module.players.indexOf(player);",
      "\tmodule.players.remove(idx);",
      "\tnetwork.broadcast(\"PlayerLeft\", { id: player.id });",
      "end);"
    ],
    "description": "Full server.pros template"
  },
  "Block Comment": {
    "prefix": "bcom",
    "body": [
      "--[[",
      "  ${1:comment}",
      "]]"
    ],
    "description": "Block comment"
  },
  "Backend Lua": {
    "prefix": "@lua",
    "body": [
      "@lua"
    ],
    "description": "Route to Lua backend"
  },
  "Backend Python": {
    "prefix": "@python",
    "body": [
      "@python"
    ],
    "description": "Route to Python backend"
  },
  "Backend CSharp": {
    "prefix": "@csharp",
    "body": [
      "@csharp"
    ],
    "description": "Route to C# backend (GUI/Studio)"
  },
  "Backend JS": {
    "prefix": "@js",
    "body": [
      "@js"
    ],
    "description": "Route to JavaScript backend (animations)"
  }
}
