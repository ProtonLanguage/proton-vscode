{
  "Variable": {
    "prefix": "var",
    "body": ["var:local ${1:name} = ${2:value};"],
    "description": "Declare a local variable"
  },
  "Constant": {
    "prefix": "const",
    "body": ["const:local ${1:NAME} = ${2:value};"],
    "description": "Declare a local constant"
  },
  "Module Variable": {
    "prefix": "module",
    "body": ["module.${1:name} = ${2:value};"],
    "description": "Declare a global module variable"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:params}) do",
      "\t${3:-- your code here}",
      "end;"
    ],
    "description": "Define a function"
  },
  "Function with return": {
    "prefix": "funcr",
    "body": [
      "func ${1:name}(${2:params}) do",
      "\t${3:-- your code here}",
      "\treturn ${4:value};",
      "end;"
    ],
    "description": "Define a function with a return value"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- your code here}",
      "end;"
    ],
    "description": "If statement"
  },
  "If / Else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- your code here}",
      "else do",
      "\t${3:-- your code here}",
      "end;"
    ],
    "description": "If / else statement"
  },
  "If / Else If / Else": {
    "prefix": "ifee",
    "body": [
      "if ${1:condition} do",
      "\t${2:-- your code here}",
      "else if ${3:condition} do",
      "\t${4:-- your code here}",
      "else do",
      "\t${5:-- your code here}",
      "end;"
    ],
    "description": "If / else if / else statement"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} do",
      "\t${2:-- your code here}",
      "end;"
    ],
    "description": "While loop"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1} to ${3:10} do",
      "\t${4:-- your code here}",
      "end;"
    ],
    "description": "For loop"
  },
  "For Each loop": {
    "prefix": "foreach",
    "body": [
      "for each ${1:item} in ${2:collection} do",
      "\t${3:-- your code here}",
      "end;"
    ],
    "description": "For each loop"
  },
  "Try / Catch": {
    "prefix": "try",
    "body": [
      "try do",
      "\t${1:-- your code here}",
      "catch ${2:error} do",
      "\tprint(\"Error: \" .. ${2:error});",
      "end;"
    ],
    "description": "Try / catch error handling"
  },
  "Print": {
    "prefix": "print",
    "body": ["print(${1:\"message\"});"],
    "description": "Print to console"
  },
  "Datastore Save": {
    "prefix": "dssave",
    "body": [
      "datastore.save(\"${1:key}\", {",
      "\t${2:field}: ${3:value}",
      "});"
    ],
    "description": "Save data to datastore"
  },
  "Datastore Load": {
    "prefix": "dsload",
    "body": [
      "var:local ${1:data} = datastore.load(\"${2:key}\");",
      "if datastore.exists(\"${2:key}\") do",
      "\t${3:-- use data here}",
      "else do",
      "\t-- no save data found",
      "end;"
    ],
    "description": "Load data from datastore"
  },
  "Server Script Header": {
    "prefix": "server",
    "body": [
      "--[[",
      "  server.pros",
      "  Proton# Multiplayer Server Script",
      "  Run this file to host a multiplayer session.",
      "]]",
      "",
      "module.players = [];",
      "module.maxPlayers = ${1:10};",
      "",
      "func onPlayerJoin(player) do",
      "\t${2:-- handle player join}",
      "end;",
      "",
      "func onPlayerLeave(player) do",
      "\t${3:-- handle player leave}",
      "end;"
    ],
    "description": "Multiplayer server script template"
  },
  "Block Comment": {
    "prefix": "bcom",
    "body": [
      "--[[",
      "  ${1:comment}",
      "]]"
    ],
    "description": "Block comment"
  },
  "Backend Lua hint": {
    "prefix": "@lua",
    "body": ["@lua"],
    "description": "Force Lua backend for this block"
  },
  "Backend Python hint": {
    "prefix": "@python",
    "body": ["@python"],
    "description": "Force Python backend for this block"
  }
}
