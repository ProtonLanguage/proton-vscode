{
  "name": "Proton",
  "scopeName": "source.proton",
  "fileTypes": ["pros"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" },
    { "include": "#module" },
    { "include": "#backend-hints" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.proton",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        },
        {
          "name": "comment.line.double-dash.proton",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.proton",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.proton",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.proton",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.proton",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.proton",
          "match": "\\b(if|else|while|for|each|in|to|do|end|return|break|continue|try|catch|throw)\\b"
        },
        {
          "name": "keyword.declaration.proton",
          "match": "\\b(var|var:local|const|const:local|func|module)\\b"
        },
        {
          "name": "keyword.operator.logical.proton",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.proton",
      "match": "\\b(int|float|string|bool|array|table)\\b"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.proton",
          "match": "\\b(true|false|null|math\\.huge)\\b"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.proton",
      "match": "\\b([0-9]+\\.?[0-9]*)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.proton",
          "match": "(\\+|-|\\*|/|%|\\*\\*)"
        },
        {
          "name": "keyword.operator.comparison.proton",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.assignment.proton",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.string.proton",
          "match": "\\.\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.proton",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.proton" },
            "2": { "name": "entity.name.function.proton" }
          }
        },
        {
          "name": "support.function.builtin.proton",
          "match": "\\b(print|typeof|tostring|toint|tofloat|len|wait|random)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.datastore.proton",
          "match": "\\b(datastore)\\.(save|load|exists|delete)\\b"
        },
        {
          "name": "variable.function.proton",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.proton",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "module": {
      "patterns": [
        {
          "name": "variable.other.module.proton",
          "match": "\\bmodule\\.[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "backend-hints": {
      "patterns": [
        {
          "name": "keyword.other.backend.proton",
          "match": "^@(lua|python|csharp)\\b"
        }
      ]
    }
  }
}
